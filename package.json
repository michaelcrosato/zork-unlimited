{
  "name": "adventureforge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "AI-authored, deterministic text RPG engine for a unified open-world adventure runtime.",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "af-replay": "./bin/replay.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format:check": "prettier --check src bin scripts agents tests blind-tester ui",
    "format": "prettier --write src bin scripts agents tests blind-tester ui",
    "lint": "eslint src bin scripts agents tests blind-tester ui",
    "test": "vitest run --reporter=dot",
    "verify:integrity": "tsx scripts/verify-integrity.ts",
    "health": "npm run verify:integrity && npm run typecheck && npm run lint && npm run format:check && npm test && npm run ui:typecheck && npm run validate",
    "test:watch": "vitest",
    "replay": "tsx bin/replay.ts",
    "validate": "tsx bin/validate.ts",
    "play": "tsx bin/rpg_play.ts",
    "overworld": "tsx bin/overworld_play.ts",
    "author": "tsx bin/author.ts",
    "inspect": "tsx bin/inspect.ts",
    "assess": "tsx bin/assess.ts",
    "corpus:seal": "npx tsx bin/seal-corpus.ts",
    "blind": "node blind-tester/blind-launch.mjs",
    "blind:smoke": "node blind-tester/smoke.mjs",
    "blind:telemetry": "node blind-tester/telemetry.mjs summary",
    "spectate": "tsx bin/spectate.ts",
    "ui:dev": "npm --prefix ui run dev",
    "ui:build": "npm --prefix ui run build",
    "mcp": "tsx src/mcp/server.ts",
    "ai:loop": "tsx src/ai-loop.ts",
    "loop:status": "bash scripts/loop-status.sh",
    "loop:stop": "bash scripts/loop-stop.sh",
    "ui:typecheck": "tsc -p ui/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.7.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fast-check": "^3.22.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
