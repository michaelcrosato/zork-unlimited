{
  "enabledPlugins": {
    "security-guidance@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(pnpm *)",
      "Bash(node *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npx *)",
      "Bash(ts-node *)",
      "Bash(bash scripts/*)"
    ],
    "deny": [
      "Bash(git push origin master*)",
      "Bash(git push origin main*)",
      "Bash(git push --force*)",
      "Bash(rm -rf /)",
      "Bash(npm publish*)",
      "Bash(pnpm publish*)",
      "Read(.env*)",
      "Read(**/.env*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-brief.sh\"",
            "shell": "bash",
            "timeout": 30,
            "statusMessage": "Briefing session from roadmap state"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-bash.sh\"",
            "shell": "bash",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/verify-gate.sh\"",
            "shell": "bash",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/commit-on-stop.sh\"",
            "shell": "bash",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "environment": {
    "setupScript": "scripts/init.sh",
    "networkPolicy": "Trusted"
  }
}
