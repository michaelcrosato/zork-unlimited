node_modules/
dist/
ui/dist/
*.log
ui/.vite-dev*.log
.DS_Store
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Ad-hoc recorded playthroughs (curated bug artifacts live in traces/bugs/)
/traces/*.json

# Autonomous AFK loop scratch evidence
ai-runs/
.tmp/
saves/*.json
transcripts/*.md
coverage/
# Rotated tail of the AFK loop log (git history preserves old AI_LOOP_STATE.md versions)
AI_LOOP_STATE_ARCHIVE.md

# Repo-local Codex config is tracked; runtime state/auth/session data is not.
.codex/*
!.codex/config.toml

# Local maintenance/runtime state
.agent-cleaner/
*.tsbuildinfo

# Local interactive-agent/browser scratch (never durable test evidence)
/.aider.chat.history.md
/.playwright-mcp/

# Blind-tester run outputs (regenerable; not source)
blind-tester/reports/*
!blind-tester/reports/.gitkeep

# Agent metadata and requests
.agents/
ORIGINAL_REQUEST.md

# Secrets — never commit. This is a public repo and the engine needs no API keys;
# any local credentials stay in an ignored env file.
.env
.env.*
!.env.example
*.pem
*.key
*.p12
secrets.json
**/credentials.json
