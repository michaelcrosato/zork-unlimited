# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Environment & secrets — agents are prohibited from reading these (CLAUDE.md §6)
.env
.env.*
*.pem
*.key

# Logs & temp
*.log
tmp/
.cache/

# …but evidence is the product of the verification contract — it MUST ship
# (evaluators open it; features.json records its paths; fresh clones resume from it)
!roadmap/evidence/**

# OS / editor junk
.DS_Store
Thumbs.db

# Claude Code local (personal) overrides — project settings stay checked in
.claude/settings.local.json

# Playwright / E2E artifacts (evidence is curated into roadmap/evidence/ instead)
test-results/
playwright-report/

# Staged review inputs (session-local)
/tmp-feedback-2.md

# Cross-CLI agent/skill mirrors generated by local tooling — the "other CLIs"
# module is explicitly deferred (docs/optional-modules.md); adopt via its own
# groomed feature, never as a side-effect of an unrelated branch
.agents/
.codex/
